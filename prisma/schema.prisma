datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  passwordHash          String
  role                  String         @default("free") // "free" or "pro"
  stripeCustomerId      String?        @unique
  stripeSubscriptionId  String?        @unique
  createdAt             DateTime       @default(now())
  reviews               ResumeReview[]
  usageLogs             UsageLog[]
}

model ResumeReview {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeText     String
  jobDescription String
  matchScore     Int
  feedback       String   // Stringified JSON containing detailed feedback breakdown
  createdAt      DateTime @default(now())
}

model UsageLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   @default("resume_review")
  createdAt DateTime @default(now())
}
